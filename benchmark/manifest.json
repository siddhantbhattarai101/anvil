{
  "description": "Ground-truth labels for the local vulnapp corpus. base_url is filled in by the runner.",
  "targets": [
    { "id": "sqli-error-numeric",  "type": "sqli", "path": "/sqli/error",  "param": "id",   "method": "GET",  "value": "1",     "expected": "vulnerable", "note": "numeric, error-based + UNION" },
    { "id": "sqli-blind-numeric",  "type": "sqli", "path": "/sqli/blind",  "param": "id",   "method": "GET",  "value": "1",     "expected": "vulnerable", "note": "boolean-blind" },
    { "id": "sqli-string-quote",   "type": "sqli", "path": "/sqli/string", "param": "name", "method": "GET",  "value": "admin", "expected": "vulnerable", "note": "single-quote string context" },
    { "id": "sqli-time-numeric",   "type": "sqli", "path": "/sqli/time",   "param": "id",   "method": "GET",  "value": "1",     "expected": "vulnerable", "note": "time-based (SLEEP)" },
    { "id": "sqli-post-body",      "type": "sqli", "path": "/sqli/post",   "param": "id",   "method": "POST", "value": "1",     "expected": "vulnerable", "note": "POST body injection" },
    { "id": "sqli-safe-param",     "type": "sqli", "path": "/sqli/safe",   "param": "id",   "method": "GET",  "value": "1",     "expected": "safe",       "note": "parameterized (must NOT flag)" },

    { "id": "xss-body-html",       "type": "xss",  "path": "/xss/body",      "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "HTML body context" },
    { "id": "xss-attr-dq",         "type": "xss",  "path": "/xss/attr",      "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "double-quote attribute" },
    { "id": "xss-attr-sq",         "type": "xss",  "path": "/xss/attr_sq",   "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "single-quote attribute" },
    { "id": "xss-js-string",       "type": "xss",  "path": "/xss/js",        "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "JS string context" },
    { "id": "xss-comment",         "type": "xss",  "path": "/xss/comment",   "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "HTML comment (needs --> escape)" },
    { "id": "xss-href-url",        "type": "xss",  "path": "/xss/href",      "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "href/URL context (javascript:)" },
    { "id": "xss-filtered-attr",   "type": "xss",  "path": "/xss/filtered",  "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "strips <>; needs attribute event-handler breakout" },
    { "id": "xss-post-body",       "type": "xss",  "path": "/xss/post",      "param": "q", "method": "POST", "value": "test", "expected": "vulnerable", "note": "reflected via POST body" },
    { "id": "xss-dom-innerhtml",   "type": "xss",  "path": "/xss/dom",       "param": "q", "method": "GET",  "value": "test", "expected": "vulnerable", "note": "DOM XSS: client reads ?q= into innerHTML" },
    { "id": "xss-safe-escaped",    "type": "xss",  "path": "/xss/safe",      "param": "q", "method": "GET",  "value": "test", "expected": "safe",       "note": "html.escape body (must NOT flag)" },
    { "id": "xss-safe-attr",       "type": "xss",  "path": "/xss/attr_safe", "param": "q", "method": "GET",  "value": "test", "expected": "safe",       "note": "escaped attribute (must NOT flag)" },
    { "id": "xss-safe-csp",        "type": "xss",  "path": "/xss/csp",       "param": "q", "method": "GET",  "value": "test", "expected": "safe",       "note": "reflected but CSP blocks execution (must NOT flag)" },

    { "id": "ssrf-fetch",          "type": "ssrf", "path": "/ssrf/fetch",      "param": "url", "method": "GET",  "value": "http://example.com", "expected": "vulnerable", "note": "fetches & returns content" },
    { "id": "ssrf-blind",          "type": "ssrf", "path": "/ssrf/blind",      "param": "url", "method": "GET",  "value": "http://example.com", "expected": "vulnerable", "note": "fetches but returns nothing (blind; needs OOB)" },
    { "id": "ssrf-post-body",      "type": "ssrf", "path": "/ssrf/post_fetch", "param": "url", "method": "POST", "value": "http://example.com", "expected": "vulnerable", "note": "POST-body SSRF" },
    { "id": "ssrf-safe-allowlist", "type": "ssrf", "path": "/ssrf/safe",       "param": "url", "method": "GET",  "value": "http://example.com", "expected": "safe",       "note": "strict allowlist (must NOT flag)" },
    { "id": "ssrf-safe-reflect",   "type": "ssrf", "path": "/ssrf/reflect",    "param": "url", "method": "GET",  "value": "http://example.com", "expected": "safe",       "note": "echoes URL, never fetches (reflection != SSRF; must NOT flag)" }
  ]
}
